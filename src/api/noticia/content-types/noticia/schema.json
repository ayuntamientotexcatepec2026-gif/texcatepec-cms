{
  "kind": "collectionType",
  "collectionName": "noticias",
  "info": {
    "singularName": "noticia",
    "pluralName": "noticias",
    "displayName": "noticia"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string"
    },
    "extracto": {
      "type": "text"
    },
    "contenido": {
      "type": "blocks"
    },
    "fecha_publicacion": {
      "type": "date"
    },
    "categoria": {
      "type": "enumeration",
      "enum": [
        "Gobierno",
        "Obras",
        "Salud",
        "Educacion",
        "Desarrollo Social",
        "Cultura",
        "Servicios",
        "General"
      ]
    },
    "imagen_destacada": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo"
    }
  }
}
